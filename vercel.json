{
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/:page.html",
      "destination": "/:page",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/:page",
      "destination": "/:page.html"
    }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/script.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
